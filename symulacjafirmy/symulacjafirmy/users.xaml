<Window x:Class="symulacjafirmy.users"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:symulacjafirmy"
        mc:Ignorable="d"
        Title="Uzytkownicy" Height="768" Width="1024">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20px"/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition Width="20px"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="20px"/>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
            <RowDefinition Height="20px"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="1" 
                   Grid.Column="1" 
                   TextAlignment="Center" 
                   FontSize="32"
                   Margin="10px">
            Uzytkownicy
        </TextBlock>
        <TextBlock Grid.Row="1" 
                   Grid.Column="3" 
                   TextAlignment="Center" 
                   FontSize="32"
                   Margin="10px">
            Symulacja Firmy
        </TextBlock>
        <DataGrid Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="2" Margin="10" AutoGenerateColumns="False"
                  x:Name="uzytkownicyGrid">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Imię" Binding="{Binding Imie}" Width="*"/>
                <DataGridTextColumn Header="Nazwisko" Binding="{Binding Nazwisko}" Width="*"/>
                <DataGridTextColumn Header="Rok Urodzenia" Binding="{Binding RokUrodzenia}" Width="*"/>

                <DataGridTemplateColumn Header="Akcje" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Edytuj" Click="EdytujUzytkownika" Tag="{Binding}" Margin="5,0"/>
                                <Button Content="Usuń" Click="UsunUzytkownika" Tag="{Binding}" Margin="5,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Grid.Column="3">

            <TextBlock FontSize="20">imie</TextBlock>
            <TextBox FontSize="20" x:Name="imie"/>

            <TextBlock FontSize="20">nazwisko</TextBlock>
            <TextBox FontSize="20" x:Name="nazwisko"/>

            <TextBlock FontSize="20">Rok urodzenia</TextBlock>
            <TextBox FontSize="20" x:Name="rokurodzenia"/>

            <Button Margin="0 10" Padding="10" FontSize="20"
            Click="zatwierdzuzytkownik">
                Dodaj / Zatwierdz
            </Button>
        </StackPanel>
    </Grid>
</Window>
