<Window x:Class="symulacjafirmy.zadania"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:symulacjafirmy"
        mc:Ignorable="d"
        Title="zadania" Height="768" Width="1024">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20px"/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition Width="20px"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="20px"/>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
            <RowDefinition Height="20px"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="1" 
                   Grid.Column="1" 
                   TextAlignment="Center" 
                   FontSize="32"
                   Margin="10px">
            Zadania
        </TextBlock>
        <TextBlock Grid.Row="1" 
                   Grid.Column="3" 
                   TextAlignment="Center" 
                   FontSize="32"
                   Margin="10px">
            Symulacja Firmy
        </TextBlock>
        <DataGrid Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="2" Margin="10" AutoGenerateColumns="False"
                  x:Name="zadnaniaGrid">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tytul" Binding="{Binding Tytul}" Width="*"/>
                <DataGridTextColumn Header="Opis" Binding="{Binding Opis}" Width="*"/>
                <DataGridTextColumn Header="Osoba" Binding="{Binding Osoba}" Width="*"/>
                <DataGridTextColumn Header="Czyzrealizowane" Binding="{Binding Czyzrealizowane}" Width="*"/>

                <DataGridTemplateColumn Header="Akcje" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Edytuj" Click="EdytujZadanie" Tag="{Binding}" Margin="5,0"/>
                                <Button Content="Usuń" Click="UsunZadanie" Tag="{Binding}" Margin="5,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Grid.Column="3">

            <TextBlock FontSize="20">Tytul</TextBlock>
            <TextBox FontSize="20" x:Name="Tytul"/>

            <TextBlock FontSize="20">Opis</TextBlock>
            <TextBox FontSize="20" x:Name="Opis"/>

            <TextBlock FontSize="20" Margin="0,10,0,0">
    Osoba
            </TextBlock>

            <ComboBox FontSize="20"
          x:Name="OsobaCombo"
          Margin="0,5,0,0"
          DisplayMemberPath="Imie"
          SelectedValuePath="Imie"/>


            

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <CheckBox x:Name="Czyzrealizowane" FontSize="20" Width="30" Height="30"/>
                <TextBlock Text="Zrealizowane" FontSize="20" VerticalAlignment="Center" Margin="5,0"/>
            </StackPanel>

            <Button Margin="0 10" Padding="10" FontSize="20"
            Click="zatwierdzZadanie">
                Dodaj / Zatwierdz
            </Button>
        </StackPanel>
    </Grid>
</Window>
